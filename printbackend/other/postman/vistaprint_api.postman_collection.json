    "variable": [
        {
            "key": "base_url",
            "value": "http://127.0.0.1:8000/api/v1",
            "type": "string"
        }
    ],
    "auth": {
        "type": "basic",
        "basic": [
            {
                "key": "password",
                "value": "password123",
                "type": "string"
            },
            {
                "key": "username",
                "value": "testuser",
                "type": "string"
            }
        ]
    },
