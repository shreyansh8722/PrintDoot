# ============================================================
# PrintDoot Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control!
# ============================================================

# ------ CORE DJANGO ------
SECRET_KEY=your-very-long-random-secret-key-here-change-this
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ------ DATABASE ------
# Railway: Use DATABASE_URL (auto-provided by Railway PostgreSQL addon)
# DATABASE_URL=postgresql://user:password@host:port/dbname
# Local: Use individual vars instead
DB_NAME=printdoot_db
DB_USER=printdoot_user
DB_PASSWORD=your-secure-database-password
DB_HOST=localhost
DB_PORT=5432

# ------ CORS / FRONTEND ------
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://yourdomain.vercel.app,https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.up.railway.app,https://yourdomain.com
FRONTEND_URL=https://yourdomain.vercel.app

# ------ SECURITY (Production) ------
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
# Obfuscate admin URL (change from default "admin/")
ADMIN_URL=secret-admin-path/

# ------ INSTAMOJO ------
INSTAMOJO_API_KEY=your-instamojo-api-key
INSTAMOJO_AUTH_TOKEN=your-instamojo-auth-token
INSTAMOJO_PRIVATE_SALT=your-instamojo-private-salt
# Use https://test.instamojo.com for sandbox, https://www.instamojo.com for production
INSTAMOJO_BASE_URL=https://www.instamojo.com

# ------ ZAKEKE ------
ZAKEKE_CLIENT_ID=your-zakeke-client-id
ZAKEKE_SECRET_KEY=your-zakeke-secret-key
ZAKEKE_WEBHOOK_SECRET=

# ------ EMAIL (SMTP) ------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# ------ SHIPROCKET ------
SHIPROCKET_EMAIL=your-shiprocket-email
SHIPROCKET_PASSWORD=your-shiprocket-password
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_WEBHOOK_TOKEN=your-random-webhook-token

# ------ FILE STORAGE (AWS S3) ------
# Set USE_S3=True to store all media files (avatars, category images,
# design assets, fonts, invoices, print files) on Amazon S3.
# When False, files are stored locally in /media/ (not recommended for production).
USE_S3=False
AWS_ACCESS_KEY_ID=AKIA...your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_STORAGE_BUCKET_NAME=printdoot
AWS_S3_REGION_NAME=ap-south-1
# Public media goes to:  s3://printdoot/media/avatars/, media/categories/, etc.
# Private media goes to: s3://printdoot/private/invoices/, private/print_files/
